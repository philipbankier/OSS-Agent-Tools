{
  "name": "automanage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first management dashboard for TasteKit traces",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild:core": "pnpm --dir ../TasteKit/tastekit --filter @tastekit/core build",
    "check": "pnpm run prebuild:core && pnpm build && pnpm test"
  },
  "dependencies": {
    "@tastekit/core": "file:../TasteKit/tastekit/packages/core",
    "chokidar": "^4.0.3",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}
